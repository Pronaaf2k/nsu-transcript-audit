{
  "expo": {
    "name": "NSU Transcript Audit",
    "slug": "nsu-transcript-audit",
    "version": "1.0.0",
    "scheme": "nsu-audit",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0f14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nsu.transcriptaudit",
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses the camera to scan transcripts",
        "NSPhotoLibraryUsageDescription": "This app accesses photos to select transcript images",
        "NSMicrophoneUsageDescription": "This app uses the microphone for video recording"
      }
    },
    "android": {
      "package": "com.nsu.transcriptaudit",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d0f14"
      },
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "CAMERA",
        "INTERNET",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9b06e25f-999d-4f92-978d-294b29d6205d"
      }
    }
  }
}
