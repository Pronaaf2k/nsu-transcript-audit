{
    "name": "mobile",
    "version": "1.0.0",
    "main": "expo-router/entry",
    "scripts": {
        "start": "node ../../scripts/check-mobile-node.cjs && expo start",
        "android": "node ../../scripts/check-mobile-node.cjs && expo run:android",
        "ios": "node ../../scripts/check-mobile-node.cjs && expo run:ios",
        "lint": "eslint .",
        "eas:build:android:apk": "node ../../scripts/check-mobile-node.cjs && npx eas-cli build -p android --profile preview",
        "eas:build:android:aab": "node ../../scripts/check-mobile-node.cjs && npx eas-cli build -p android --profile production"
    },
    "dependencies": {
        "@expo/vector-icons": "^15.1.1",
        "@react-native-async-storage/async-storage": "^2.2.0",
        "@react-navigation/native": "^7.2.2",
        "@supabase/supabase-js": "^2.39.0",
        "expo": "~54.0.33",
        "expo-auth-session": "~7.0.10",
        "expo-camera": "~17.0.10",
        "expo-constants": "~18.0.13",
        "expo-document-picker": "~14.0.8",
        "expo-file-system": "~19.0.21",
        "expo-font": "~14.0.11",
        "expo-linking": "~8.0.11",
        "expo-router": "~6.0.23",
        "expo-status-bar": "~3.0.9",
        "expo-web-browser": "~15.0.10",
        "react": "19.1.0",
        "react-native": "0.81.5",
        "react-native-safe-area-context": "~5.6.2",
        "react-native-screens": "~4.16.0",
        "react-native-url-polyfill": "^2.0.0"
    },
    "devDependencies": {
        "@babel/core": "^7.20.0",
        "@types/node": "^20.19.9",
        "@types/react": "~19.1.17",
        "typescript": "^5.1.3"
    }
}
