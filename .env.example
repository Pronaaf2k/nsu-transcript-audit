# =============================================================================
# NSU Transcript Audit - unified local env template
# Copy this file to .env at repo root and fill values.
# =============================================================================

# ─── Supabase (shared across web/api/cli/mobile) ─────────────────────────────
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-supabase-anon-key>
SUPABASE_JWT_SECRET=<your-supabase-jwt-secret>

# Optional: only needed if you use server-side writes to Supabase from API
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# ─── API / OCR ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=<your-gemini-api-key>

# Local API base URL used by clients
NEXT_PUBLIC_API_URL=http://localhost:8000
EXPO_PUBLIC_API_URL=http://localhost:8000
GRADGATE_API_URL=http://localhost:8000

# ─── Web (Next.js) ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# ─── Mobile (Expo) ────────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>
