# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# ─── FastAPI Audit Server (on Render) ───────────────────────────────────────
# OCR is handled by Tesseract on the Render server — free, unlimited, no API key needed
AUDIT_API_URL=https://nsu-audit-api.onrender.com
AUDIT_API_KEY=<your-render-generated-audit-key>

# ─── Used by CLI & k6 load tests ────────────────────────────────────────────
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-supabase-anon-key>
